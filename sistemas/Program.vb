Imports System

Module Program
    Sub Main(args As String())

        Dim sistemas(4) as string

        sistemas(0) = "Windows"
        sistemas(1) = "Linux"
        sistemas(2) = "IOS"

        Console.writeline("Os sitemas operacionais são:")
        Console.writeline(sistemas(0))
        console.writeline(sistemas(1))
        console.writeline(sistemas(2))

        Console.writeline("Agora escolha um sistema operacional:")

        sistemas(4) = console.readline()

        If 
        sistemas(4) = Linux
        Console.writeline("Usuário de linux é bom!")

         Else if
        sistemas(4) = Windows
        console.writeline("Usuario de windows é fraco")

        Else
        sistemas(4) = IOS
        
        Console.writeline("IOS não compensa")

        end if




    End Sub
End Module
