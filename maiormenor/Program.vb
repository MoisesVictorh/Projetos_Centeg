Imports System

Module Program
    Sub Main(args As String())

        Dim num1 as Integer  
        Dim num2 as Integer  

        Console.WriteLine("Me informe o primeiro número:")

        num1 = console.readline()

        Console.WriteLine("Agora me informe o segundo número:")

        num2 = console.readline()

        if num1 > num2

        console.writeline (num1 & " é maior que " & num2)

        else if num1 < num2

            console.writeline (num2 & " é maior que " & num1)

        Else

            Console.writeline ("Os números são iguais")

        end if  








    End Sub
End Module
